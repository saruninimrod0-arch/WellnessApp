<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#673AB7"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

<!-- Below is a Linear Layout that holds all our view -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:orientation="vertical">

        <!--Below is a Textview  -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="Health and Wellness App"
        android:textSize="45sp"
        android:textAlignment="center"
        android:textStyle="bold"
        android:textColor="#EF0A3C"/>

       <!--Below is an image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@drawable/image3" />

        <com.google.android.gms.ads.AdView
            android:id="@+id/adView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:adSize="BANNER"
            app:adUnitId="ca-app-pub-3940256099942544/6300978111"/>




        <!--Below is button number one      -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/Health_Receipt"
            android:drawableLeft="@drawable/health"
            android:text="Health Recipe"
            android:textSize="20sp"
            android:backgroundTint="#4CAF50"
            android:layout_marginTop="15dp"/>



        <!--Below is button number two        -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/nutrition_advice"
            android:text="Nutrition Advice"
            android:textSize="20sp"
            android:drawableLeft="@drawable/nutrition"

            android:backgroundTint="#CA1653"
            android:layout_marginTop="15dp"/>

        <!--Below is button number three        -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/Meditation_advice"
            android:text="Meditation"
            android:drawableLeft="@drawable/meditation"
            android:textSize="20sp"
            android:backgroundTint="#D312B9"
            android:layout_marginTop="15dp"/>

        <!--Below is button number four       -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/Hydration_Alert"
            android:text="Hydrarion Alert"
            android:drawableLeft="@drawable/hydration"
            android:textSize="20sp"
            android:backgroundTint="#CA1C0F"
            android:layout_marginTop="15dp"/>

        <!--Below is button number five       -->

        <!--Below is button number six       -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/Daily_Motivation"
            android:drawableLeft="@drawable/motivation"

            android:text="Daily Motivation"
            android:textSize="20sp"
            android:backgroundTint="#E91E63"
            android:layout_marginTop="15dp"/>

        <!--Below is button number seven      -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/Weekly_Goals"
            android:drawableLeft="@drawable/goals"

            android:text="Weekly Goals"
            android:textSize="20sp"
            android:backgroundTint="#62667E"
            android:layout_marginTop="15dp"/>

        <!--Below is button number eight    -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/Exercise_Activity"
            android:drawableLeft="@drawable/running"

            android:text="Exercise Activity"
            android:textSize="20sp"
            android:backgroundTint="#E6D015"
            android:layout_marginTop="15dp"/>



        <!--Below is button number nine     -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/Progress_Activity"
            android:text="Progress Activity"
            android:drawableLeft="@drawable/process"
            android:textSize="20sp"
            android:backgroundTint="#D15731"
            android:layout_marginTop="15dp"/>

        <!--Below is button number ten     -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/Learnmore"
            android:text="Learn more..."
            android:textSize="20sp"
            android:drawableLeft="@drawable/learnmore"

            android:backgroundTint="#CA1C0F"
            android:layout_marginTop="15dp"/>







    </LinearLayout>

</ScrollView>